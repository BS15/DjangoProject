# ============================================================
# Environment variables used by this Django project.
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env with real secrets.
# ============================================================

# ------------------------------------------------------------------
# Django core
# ------------------------------------------------------------------

# Generate a key with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-real-secret-key

# True for local development, False for production
DEBUG=False

# Comma-separated list, ex: 127.0.0.1,localhost,.app.github.dev
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated origins including scheme.
# Required when accessing the app through nginx (http://localhost).
# Add Codespaces URLs here when developing in GitHub Codespaces.
# Example: https://*.app.github.dev,http://localhost
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# ------------------------------------------------------------------
# Database (Docker / PostgreSQL — default)
# ------------------------------------------------------------------

# Database backend for the Docker stack (PostgreSQL service named "db" in compose).
# For local development without Docker, see the "Local-only" block below.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=djangodb
DB_USER=djangouser
DB_PASSWORD=replace-with-db-password
DB_HOST=db
DB_PORT=5432

# Credentials consumed by the PostgreSQL container itself (must match DB_* values above)
POSTGRES_DB=djangodb
POSTGRES_USER=djangouser
POSTGRES_PASSWORD=replace-with-db-password

# ------------------------------------------------------------------
# Database — Local-only (no Docker)
# ------------------------------------------------------------------
# Uncomment the block below and comment out the Docker block above
# when running manage.py directly without docker-compose.
#
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# ------------------------------------------------------------------
# Static files
# ------------------------------------------------------------------

# collectstatic destination inside the Docker container
STATIC_ROOT=/app/staticfiles

# ------------------------------------------------------------------
# Reverse proxy / security
# ------------------------------------------------------------------

# When DEBUG=False, defaults to True in settings.py
SECURE_SSL_REDIRECT=False

# Enable only behind a trusted proxy that sets X-Forwarded-Proto
USE_X_FORWARDED_PROTO=False

# Optional Gunicorn tuning for docker-compose
# GUNICORN_WORKERS=3

# ------------------------------------------------------------------
# External APIs
# ------------------------------------------------------------------

AUTENTIQUE_API_TOKEN=

# ------------------------------------------------------------------
# PDF templates (optional)
# ------------------------------------------------------------------

# Path to the institutional letterhead PDF used as background in generated documents.
# LETTERHEAD_PATH=/absolute/path/to/papel_timbrado.pdf

# Legacy alias (still accepted for existing deployments):
# CRECI_LETTERHEAD_PATH=/absolute/path/to/papel_timbrado_creci_sc.pdf

# ------------------------------------------------------------------
# Institutional identity (embedded in PDF receipts and documents)
# ------------------------------------------------------------------

# Full legal name of the organization, e.g.:
# ORGAO_NOME_COMPLETO=Conselho Regional de Corretores de Imóveis de Santa Catarina - 11ª Região (CRECI-SC)
ORGAO_NOME_COMPLETO=

# CNPJ of the organization (used to identify bank transactions in payment receipts)
ORGAO_CNPJ=

# Bank branch (agência) and account number (conta) of the organization
ORGAO_BANCO_AGENCIA=
ORGAO_BANCO_CONTA=

