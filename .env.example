# ============================================================
# Environment variables required by this Django project.
# Copy this file to .env and fill in the values for your
# environment.  NEVER commit a .env file with real secrets.
# ============================================================

# ------------------------------------------------------------------
# Django core – REQUIRED in production
# ------------------------------------------------------------------

# Generate a new key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production; True only for local development
DEBUG=False

# Comma-separated list of domains/IPs that Django will serve
# Example: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Comma-separated list of trusted origins for CSRF (required when running behind
# a reverse proxy such as Nginx).  Include the scheme.
# Example: http://10.0.0.5,https://myapp.example.com
CSRF_TRUSTED_ORIGINS=http://yourdomain.com,https://yourdomain.com

# ------------------------------------------------------------------
# Database – REQUIRED in production (PostgreSQL)
# ------------------------------------------------------------------

DB_ENGINE=django.db.backends.postgresql
DB_NAME=djangodb
DB_USER=djangouser
DB_PASSWORD=your-db-password-here
DB_HOST=db
DB_PORT=5432

# PostgreSQL container credentials (used by the db service in docker-compose.yml)
POSTGRES_DB=djangodb
POSTGRES_USER=djangouser
POSTGRES_PASSWORD=your-db-password-here

# ------------------------------------------------------------------
# Static files – REQUIRED in production
# ------------------------------------------------------------------

# Absolute path where `collectstatic` should deposit files.
# Inside Docker the default /app/staticfiles is used; override only if needed.
STATIC_ROOT=/app/staticfiles

# ------------------------------------------------------------------
# Security – OPTIONAL
# ------------------------------------------------------------------

# Set to False for local-network (HTTP-only) deployments that do not yet use TLS.
# Defaults to True when DEBUG=False.
SECURE_SSL_REDIRECT=False

# Set to True when the application runs behind a trusted reverse proxy (Nginx)
# that forwards the X-Forwarded-Proto header.
USE_X_FORWARDED_PROTO=True

# Number of Gunicorn worker processes (default: 3). Rule of thumb: 2 * CPU cores + 1.
# GUNICORN_WORKERS=3

# ------------------------------------------------------------------
# External APIs
# ------------------------------------------------------------------

# Google Gemini API key (required for AI-powered document extraction)
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ------------------------------------------------------------------
# PDF templates – OPTIONAL
# ------------------------------------------------------------------

# Absolute path to the CRECI-SC letterhead PDF used as a background for
# auto-generated documents (payment authorisation, fiscal-council opinion).
# Defaults to processos/pdf_templates/papel_timbrado_creci_sc.pdf inside
# the project directory; override here when deploying with a different file.
# CRECI_LETTERHEAD_PATH=/absolute/path/to/papel_timbrado_creci_sc.pdf

