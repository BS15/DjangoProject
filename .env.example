# ============================================================
# Environment variables used by this Django project.
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env with real secrets.
# ============================================================

# ------------------------------------------------------------------
# Django core
# ------------------------------------------------------------------

# Generate a key with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-real-secret-key

# True for local development, False for production
DEBUG=False

# Comma-separated list, ex: 127.0.0.1,localhost,.app.github.dev
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated origins including scheme.
# Example for Codespaces + localhost:
# https://*.app.github.dev,https://localhost:8001,https://localhost,http://localhost:8001,http://127.0.0.1:8001
CSRF_TRUSTED_ORIGINS=

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------

# Defaults in settings.py are SQLite values, but explicit values are useful.
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=/workspaces/DjangoProject/db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Optional variables used by docker-compose PostgreSQL service
POSTGRES_DB=djangodb
POSTGRES_USER=djangouser
POSTGRES_PASSWORD=replace-with-db-password

# ------------------------------------------------------------------
# Static files
# ------------------------------------------------------------------

# collectstatic destination
STATIC_ROOT=/workspaces/DjangoProject/staticfiles

# ------------------------------------------------------------------
# Reverse proxy / security
# ------------------------------------------------------------------

# When DEBUG=False, defaults to True in settings.py
SECURE_SSL_REDIRECT=False

# Enable only behind a trusted proxy that sets X-Forwarded-Proto
USE_X_FORWARDED_PROTO=False

# Optional Gunicorn tuning for docker-compose
# GUNICORN_WORKERS=3

# ------------------------------------------------------------------
# External APIs
# ------------------------------------------------------------------

AUTENTIQUE_API_TOKEN=

# ------------------------------------------------------------------
# PDF templates (optional)
# ------------------------------------------------------------------

# CRECI_LETTERHEAD_PATH=/absolute/path/to/papel_timbrado_creci_sc.pdf

