# Ambientes Virtuais
.venv/
.venv*/
venv/
env/

# Memórias/instruções locais de agente (não versionar)
memories/
.memories/
.ai-memory/
.copilot-memory/

# Banco de Dados Local (NUNCA suba o banco de dados)
db.sqlite3

# Arquivos de mídia (Uploads, PDFs, imagens)
media/

# Arquivos temporários do Python e PyCharm
__pycache__/
*.pyc
.idea/
.env

# Arquivos temporários gerais
temp/

# Arquivos estáticos coletados (gerados pelo collectstatic, não devem ser versionados)
staticfiles/

# Documentação gerada por mkdocs (não versionar o build — gerar em CI)
site/

# Hypothesis internal cache (gerado automaticamente pelos testes de fuzzing)
.hypothesis/

# Dev Container cache e arquivos locais
.devcontainer/cache/
.devcontainer/.env.local

# Arquivos pessoais de rascunho / artefatos locais de depuração (nunca versionar)
# Coloque qualquer arquivo temporário pessoal dentro de local/ — toda a pasta é ignorada.
local/
